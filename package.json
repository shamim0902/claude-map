{
  "name": "claude-map",
  "version": "1.1.2",
  "description": "Visual dashboard for inspecting and mapping Claude Code project configurations",
  "main": "server.js",
  "bin": {
    "claude-map": "bin/cli.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "postinstall": "cd node_modules/node-pty && npx node-gyp rebuild 2>/dev/null || true"
  },
  "files": [
    "bin/",
    "public/",
    "server.js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "claude-map",
    "anthropic",
    "ai",
    "dashboard",
    "inspector",
    "configuration",
    "skills",
    "commands",
    "mcp"
  ],
  "author": "shamim0902",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shamim0902/claude-map.git"
  },
  "homepage": "https://github.com/shamim0902/claude-map#readme",
  "bugs": {
    "url": "https://github.com/shamim0902/claude-map/issues"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
